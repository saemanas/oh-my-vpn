{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Oh My VPN",
  "version": "0.1.0",
  "identifier": "com.saemanas.oh-my-vpn",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Oh My VPN",
        "width": 320,
        "height": 480,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/wireguard-go",
      "binaries/wg",
      "binaries/wg-quick"
    ]
  }
}
